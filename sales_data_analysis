    "# Creating summary table\n",
    "\n",
    "num_values= df[[\"Store_Area\" , \"Number_of_Employees\", \"Customer_Footfall\", \"Monthly_Sales\"]]\n",
    "summary =num_values.describe().T\n",
    "\n",
    "summary_clean = summary[[\"count\", \"min\", \"50%\", \"max\",\"mean\", \"std\"]].copy()\n",
    "\n",
    "missing= num_values.isnull().sum()\n",
    "summary_clean[\"Missing\"] = missing\n",
    "\n",
    "summary_clean = summary_clean.rename(index={\n",
    "    \"Store_Area\": \"Store Area (sqm)\",\n",
    "    \"Number_of_Employees\": \"Number of Employees\",\n",
    "    \"Customer_Footfall\": \"Customer Footfall\",\n",
    "    \"Monthly_Sales\": \"Monthly Sales (€)\"\n",
    "    })\n",
    "summary_clean = summary_clean.rename(columns={\n",
    "    \"count\": \"Observations\",\n",
    "    \"mean\": \"Mean\",\n",
    "    \"std\": \"Std Dev\",\n",
    "    \"min\": \"Minimum\",\n",
    "    \"50%\": \"Median\",\n",
    "    \"max\": \"Maximum\"\n",
    "    })\n",
    "\n",
    "total_rows = len(df)\n",
    "summary_clean[\"Missing %\"] = (summary_clean[\"Missing\"] / total_rows * 100)\n",
    "\n",
    "summary_clean = summary_clean[[\n",
    "    \"Missing\",\n",
    "    \"Missing %\",\n",
    "    \"Observations\",\n",
    "    \"Minimum\",\n",
    "    \"Median\",\n",
    "    \"Maximum\",\n",
    "    \"Mean\",\n",
    "    \"Std Dev\",\n",
    "    ]]\n",
    "rounding_cols = [\"Missing\", \"Observations\", \"Minimum\", \"Median\", \"Maximum\"]\n",
    "one_decimal =[\"Missing %\", \"Mean\", \"Std Dev\"]\n",
